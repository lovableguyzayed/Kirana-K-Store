# ==============================================================================
# Environment template — copy to `.env` for local development.
# NEVER commit a real `.env` file. On Render, set these in the dashboard
# (Environment tab). See DEPLOYMENT.md for where each value comes from.
# ==============================================================================

# --- API server (artifacts/api-server) ---------------------------------------

# Port the Express server listens on. Render injects PORT automatically —
# only needed locally.
PORT=3001

# Postgres connection string. Get it from the Supabase dashboard:
# click "Connect" (top bar) and pick the right tab for the job.
#
#   For the API server on Render — "Transaction pooler" (IPv4-compatible):
#     postgresql://postgres.oxekfjyvboccekwjafcq:<PASSWORD>@aws-1-<region>.pooler.supabase.com:6543/postgres
#   For migrations (drizzle-kit push) — "Session pooler":
#     postgresql://postgres.oxekfjyvboccekwjafcq:<PASSWORD>@aws-1-<region>.pooler.supabase.com:5432/postgres
#
#   NOTE: the "Direct connection" string
#   (db.oxekfjyvboccekwjafcq.supabase.co:5432) is IPv6-only — it will NOT
#   work from Render or most local ISPs. Use the poolers above.
DATABASE_URL=

# TLS for the Postgres connection. Defaults to ON when NODE_ENV=production
# (required by Supabase). Set to "false" only for a local Postgres without TLS.
# DATABASE_SSL=true

# Comma-separated list of origins allowed by CORS. Unset = allow all (dev only).
# ALLOWED_ORIGINS=https://app.yourdomain.com

# --- Supabase (for Auth / Storage integration) -------------------------------
# Project Settings → API keys. The publishable key is safe to ship in clients;
# the secret (service_role) key is server-only and must never reach the app
# bundle or this file's committed template.
SUPABASE_URL=https://oxekfjyvboccekwjafcq.supabase.co
SUPABASE_ANON_KEY=sb_publishable__MTgIhGcPX5QmLFlYFWv-g_X7BsYFq2
# SUPABASE_SERVICE_ROLE_KEY=

# --- Expo app (artifacts/kirana-konnect) -------------------------------------
# Anything prefixed EXPO_PUBLIC_ is embedded in the app bundle at build time —
# never put secrets here. URL + publishable key have safe defaults compiled
# into utils/supabase.ts; set them here only to point at a different project.
# EXPO_PUBLIC_API_URL=https://kirana-api.onrender.com
# EXPO_PUBLIC_SUPABASE_URL=https://oxekfjyvboccekwjafcq.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable__MTgIhGcPX5QmLFlYFWv-g_X7BsYFq2
